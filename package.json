{
  "name": "@navikt/astro-mocks",
  "version": "0.1.5",
  "description": "Astro integration that serves mock HTTP endpoints during development only.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "astro",
    "astro-integration",
    "astro-component",
    "mock",
    "mock-server",
    "development",
    "withastro"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/navikt/tms-astro-mocks.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {},
  "peerDependencies": {
    "astro": ">=4.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "astro": "^7.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.14.1"
  }
}
